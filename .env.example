# WhatsApp Command Channel — copy to `.env` and fill in. Never commit your real `.env`.
# Every value below is a placeholder; nothing here ties to any account.

# ── Required ──────────────────────────────────────────────────────────────────
WA_TO=15551234567   # YOUR phone number in international format, digits only (no +). The only value you must set.
WA_LID=             # Optional WhatsApp privacy id; leave blank to accept messages from WA_TO.

# ── Claude command center (optional — leave all blank for the $0 ack channel) ──
# Mode is auto-detected: `claude` CLI present -> cli, else -> ack. No API key anywhere.
CC_MODE=            # force a mode: cli | ack   (blank = auto-detect)

# cli mode — full agent with tools, using YOUR OWN Claude login (the `claude` CLI).
# Nothing metered here; it's the same Claude you already use at the terminal.
CLAUDE_BIN=         # path/name of the claude CLI if it isn't just "claude" on PATH
CC_WORKDIR=         # working dir Claude runs in (blank = current dir)
CC_YOLO=            # set to 1 to pass --dangerously-skip-permissions (trusted machine only)
CC_TIMEOUT_MS=      # per-message timeout in ms (blank = 240000)
CC_SYSTEM=          # optional extra system-prompt text (e.g. "You are my ops assistant over WhatsApp.")
